# Electron application settings
LARAVEL_API_BASE_URL=http://127.0.0.1:8000/api/v1
API_TIMEOUT_MS=15000
SYNC_INTERVAL_SECONDS=60
TIMER_PERSIST_INTERVAL_SECONDS=5
ADMIN_EXIT_PASSWORD=change-this-admin-password

# Laravel OTP authentication settings
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_LOCK_SECONDS=300
SANCTUM_TOKEN_EXPIRY_MINUTES=1440
